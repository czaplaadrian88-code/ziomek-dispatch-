[Unit]
Description=Ziomek MP-#9 Telegram Heartbeat — runs every 60s
Documentation=https://github.com/czaplaadrian88-code/ziomek-dispatch- (MP-#9)

[Timer]
# OnBootSec=2min — bot zwykle zaczyna ~30s po boot, dajemy buffer dla cleanup state
OnBootSec=2min
OnUnitActiveSec=60s
AccuracySec=5s
Unit=dispatch-tg-heartbeat.service
Persistent=false

[Install]
WantedBy=timers.target
