{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ziomek-change-gate-registry-v1.schema.json",
  "title": "Ziomek Codex skills registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "purpose",
    "skills"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "registry_id": {
      "const": "ziomek-codex-skills"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "skill_id",
          "name",
          "version",
          "scope",
          "owner",
          "status",
          "staged_candidate_path",
          "activation_target",
          "activation_allowed",
          "source",
          "trigger",
          "allowed_actions",
          "forbidden_actions",
          "authority",
          "policy_contract",
          "owned_paths",
          "candidate_effect_boundary",
          "pin",
          "update",
          "rollback",
          "threat_boundary"
        ],
        "properties": {
          "skill_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "const": "STAGED_ONLY_REVIEW_REQUIRED"
          },
          "staged_candidate_path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^docs/codex-skills/candidates/[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "activation_target": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\.agents/skills/[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "activation_allowed": {
            "const": false
          },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "base_commit",
              "rejected_candidate_commit",
              "rejected_tree",
              "candidate_commit",
              "candidate_tree",
              "provenance_disposition",
              "license_disposition"
            ],
            "properties": {
              "kind": {
                "const": "LOCAL_ZIOMEK_AUTHORED"
              },
              "base_commit": {
                "type": "string",
                "minLength": 1
              },
              "rejected_candidate_commit": {
                "type": "string",
                "minLength": 1
              },
              "rejected_tree": {
                "type": "string",
                "minLength": 1
              },
              "candidate_commit": {
                "const": "UNPINNED_UNTIL_INDEPENDENT_REVIEW"
              },
              "candidate_tree": {
                "const": "UNPINNED_UNTIL_INDEPENDENT_REVIEW"
              },
              "provenance_disposition": {
                "enum": [
                  "NEW_LOCAL_CANDIDATE",
                  "REMEDIATION_OF_REJECTED_CANDIDATE"
                ]
              },
              "license_disposition": {
                "const": "INTERNAL_REPOSITORY_ONLY"
              }
            }
          },
          "trigger": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "summary",
              "contexts"
            ],
            "properties": {
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "contexts": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "allowed_actions": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "forbidden_actions": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "authority": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "network",
              "production",
              "deploy",
              "restart",
              "flag_mutation",
              "data_mutation",
              "migration",
              "lease",
              "tmux",
              "owner_ack",
              "business_semantics"
            ],
            "properties": {
              "network": {
                "const": false
              },
              "production": {
                "const": false
              },
              "deploy": {
                "const": false
              },
              "restart": {
                "const": false
              },
              "flag_mutation": {
                "const": false
              },
              "data_mutation": {
                "const": false
              },
              "migration": {
                "const": false
              },
              "lease": {
                "const": false
              },
              "tmux": {
                "const": false
              },
              "owner_ack": {
                "const": false
              },
              "business_semantics": {
                "const": false
              }
            }
          },
          "policy_contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "schema_version",
              "rules"
            ],
            "properties": {
              "schema_version": {
                "const": "1.0"
              },
              "rules": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "code",
                    "subject",
                    "relation",
                    "object",
                    "enforcement"
                  ],
                  "properties": {
                    "code": {
                      "type": "string",
                      "pattern": "^[A-Z][A-Z0-9_]*$"
                    },
                    "subject": {
                      "type": "string",
                      "pattern": "^[A-Z][A-Z0-9_]*$"
                    },
                    "relation": {
                      "type": "string",
                      "pattern": "^[A-Z][A-Z0-9_]*$"
                    },
                    "object": {
                      "type": "string",
                      "pattern": "^[A-Z][A-Z0-9_]*$"
                    },
                    "enforcement": {
                      "const": "FAIL_CLOSED"
                    }
                  }
                }
              }
            }
          },
          "owned_paths": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*//)[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
            }
          },
          "candidate_effect_boundary": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "write_set_semantics",
              "root_source",
              "allowed_paths_source",
              "shared_governance_paths_allowed",
              "cross_skill_paths_allowed",
              "path_comparison",
              "file_type_policy"
            ],
            "properties": {
              "write_set_semantics": {
                "const": "EXACT_CHANGED_CANDIDATE_RUNTIME_ARTIFACT_FILES"
              },
              "root_source": {
                "const": "staged_candidate_path"
              },
              "allowed_paths_source": {
                "const": "pin.candidate_artifacts.files[].path"
              },
              "shared_governance_paths_allowed": {
                "const": false
              },
              "cross_skill_paths_allowed": {
                "const": false
              },
              "path_comparison": {
                "const": "EXACT_BYTES_PLUS_NFKC_CASEFOLD_COLLISION_REJECTION"
              },
              "file_type_policy": {
                "const": "REGULAR_NON_SYMLINK_ONLY"
              }
            }
          },
          "pin": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "policy",
              "moving_branch_allowed",
              "exact_byte_activation_required",
              "first_canary_invocation",
              "candidate_artifacts"
            ],
            "properties": {
              "policy": {
                "const": "EXACT_REVIEWED_COMMIT_AND_TREE"
              },
              "moving_branch_allowed": {
                "const": false
              },
              "exact_byte_activation_required": {
                "const": true
              },
              "first_canary_invocation": {
                "const": "EXPLICIT_ONLY"
              },
              "candidate_artifacts": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "algorithm",
                  "files"
                ],
                "properties": {
                  "algorithm": {
                    "const": "SHA-256"
                  },
                  "files": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "path",
                        "sha256"
                      ],
                      "properties": {
                        "path": {
                          "type": "string",
                          "minLength": 1,
                          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*//)[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
                        },
                        "sha256": {
                          "type": "string",
                          "pattern": "^[0-9a-f]{64}$"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "update": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "policy",
              "requirements"
            ],
            "properties": {
              "policy": {
                "const": "NEW_STAGED_CANDIDATE_THEN_INDEPENDENT_REVIEW"
              },
              "requirements": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "rollback": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "policy",
              "anchor_tag",
              "scope",
              "live_action_required"
            ],
            "properties": {
              "policy": {
                "const": "REVERT_ANNOTATED_LOCAL_TAG_COMMIT"
              },
              "anchor_tag": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
              },
              "scope": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "live_action_required": {
                "const": false
              }
            }
          },
          "threat_boundary": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "staged_outside_discovery",
              "staged_path_symlink_allowed",
              "staged_executable_allowed",
              "implicit_invocation_allowed",
              "official_loader_consumer",
              "future_move_is_activation",
              "product_runtime_consumer"
            ],
            "properties": {
              "staged_outside_discovery": {
                "const": true
              },
              "staged_path_symlink_allowed": {
                "const": false
              },
              "staged_executable_allowed": {
                "const": false
              },
              "implicit_invocation_allowed": {
                "const": false
              },
              "official_loader_consumer": {
                "const": "CODEX_REPO_SKILL_DISCOVERY"
              },
              "future_move_is_activation": {
                "const": true
              },
              "product_runtime_consumer": {
                "const": false
              }
            }
          }
        }
      }
    }
  }
}
