+"""Test ON!=OFF flagi ENABLE_CTO_FIXTURE_DEMO (fixture skilla ziomek-cto)."""
+
+
+def test_cto_fixture_demo_on_neq_off(monkeypatch):
+    import core.selection as sel
+    monkeypatch.setattr(sel._dp.C, "decision_flag", lambda n: n == "ENABLE_CTO_FIXTURE_DEMO")
+    on = sel._cto_fixture_demo_bonus(object())
+    monkeypatch.setattr(sel._dp.C, "decision_flag", lambda n: False)
+    off = sel._cto_fixture_demo_bonus(object())
+    assert on != off, "flaga ENABLE_CTO_FIXTURE_DEMO musi zmieniac decyzje (ON != OFF)"
+    assert on == 1.0 and off == 0.0
+
